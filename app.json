{
  "expo": {
    "name": "TuitionTrack",
    "slug": "TuitionTrack",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/TuitionTracklogo.png",
    "scheme": "tuitiontrack",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.shakibmehrab.TuitionTrack"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/TuitionTracklogo.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/TuitionTracklogo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.shakibmehrab.TuitionTrack"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/TuitionTracklogo.png"
    },
    "plugins": [
      "expo-router",
      "@react-native-firebase/app",
      "@react-native-google-signin/google-signin",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/TuitionTracklogo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ed8f80f7-c24c-4925-8c61-94301399eea7"
      }
    },
    "owner": "shakib-mehrab"
  }
}
