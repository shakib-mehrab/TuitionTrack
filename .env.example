# Firebase Configuration Template
# Copy this file to .env and fill in your actual Firebase credentials
# Get these values from Firebase Console > Project Settings > Your apps

FIREBASE_API_KEY=your_api_key_here
FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id

# Google Sign-In
# Get from: Firebase Console > Authentication > Sign-in method > Google > Web SDK configuration > Web client ID
GOOGLE_WEB_CLIENT_ID=your_web_client_id_here
